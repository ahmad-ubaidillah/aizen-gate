{
	"name": "aizen-gate",
	"version": "2.3.2",
	"description": "The Ultimate AI-Orchestration & Specification Shield",
	"main": "dist/index.js",
	"type": "module",
	"bin": {
		"aizen-gate": "./dist/bin/cli.js"
	},
	"files": [
		"dist",
		"bin",
		"src",
		"adapters",
		"agents",
		"commands",
		"completions",
		"dashboard",
		"docs",
		"shared",
		"skill-creator",
		"skills",
		"templates",
		"installer",
		".agent",
		"AIZEN_GATE.md",
		"GEMINI.md",
		"ONBOARDING.md",
		"biome.json",
		"module.yaml",
		"profiles.yaml"
	],
	"scripts": {
		"dev": "npm run build && npm run az-start",
		"build": "tsc && npm run build:bundle",
		"build:bundle": "node scripts/build.js",
		"postinstall": "node -e \"console.log('\\n✅ Aizen-Gate Ready!\\n\\n⛩️  To initialize your project, run:\\n   npx aizen-gate install\\n\\n🚀 Enjoy the Elite Swarm Experience!\\n')\"",
		"build:watch": "tsc --watch",
		"clean": "rm -rf dist",
		"test": "vitest",
		"test:run": "vitest run",
		"e2e": "playwright test",
		"az-start": "node ./bin/cli.js start",
		"az-status": "node ./bin/cli.js status",
		"az-tokens": "node ./bin/cli.js tokens",
		"az-kg": "node ./bin/cli.js kg",
		"format": "biome format --write ./",
		"lint": "biome lint --write ./",
		"check": "npx @biomejs/biome check --write ./",
		"typecheck": "tsc --noEmit",
		"security-check": "./src/utils/security-check.sh"
	},
	"keywords": [
		"ai",
		"agents",
		"scrum",
		"development",
		"orchestrator",
		"claude",
		"cursor",
		"gemini"
	],
	"author": "Aizen-Gate Team",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ahmad-ubaidillah/aizen-gate"
	},
	"bugs": {
		"url": "https://github.com/ahmad-ubaidillah/aizen-gate/issues"
	},
	"homepage": "https://github.com/ahmad-ubaidillah/aizen-gate#readme",
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"@hono/node-server": "^1.13.7",
		"@inquirer/prompts": "^8.3.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"better-sqlite3": "^12.6.2",
		"chalk": "^4.1.2",
		"commander": "^11.0.0",
		"gray-matter": "^4.0.3",
		"hono": "^4.6.14",
		"js-yaml": "^4.1.0",
		"ws": "^8.19.0",
		"axios": "^1.6.0",
		"cheerio": "^1.0.0-rc.12",
		"fs-extra": "^11.2.0"
	},
	"optionalDependencies": {
		"@xenova/transformers": "^2.17.2",
		"node-llama-cpp": "^3.17.1",
		"sharp": "^0.32.6"
	},
	"devDependencies": {
		"@playwright/test": "^1.40.0",
		"@types/node": "^25.3.5",
		"@types/ws": "^8.18.1",
		"@vitest/coverage-v8": "^4.0.18",
		"esbuild": "^0.27.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.3.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"yaml": "^2.8.2"
	}
}
