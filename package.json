{
	"name": "aizen-gate",
	"version": "2.1.0",
	"description": "The Ultimate AI-Orchestration & Specification Shield",
	"main": "index.js",
	"type": "commonjs",
	"bin": {
		"aizen-gate": "./bin/cli.js"
	},
	"files": [
		"bin",
		"src",
		"adapters",
		"agents",
		"commands",
		"completions",
		"dashboard",
		"docs",
		"shared",
		"skill-creator",
		"skills",
		"templates",
		"installer",
		"AIZEN_GATE.md",
		"GEMINI.md",
		"biome.json",
		"module.yaml",
		"profiles.yaml"
	],
	"scripts": {
		"test": "vitest",
		"test:run": "vitest run",
		"az-start": "node ./bin/cli.js start",
		"az-status": "node ./bin/cli.js status",
		"az-tokens": "node ./bin/cli.js tokens",
		"az-kg": "node ./bin/cli.js kg",
		"format": "biome format --write ./",
		"lint": "biome lint --write ./",
		"check": "npx @biomejs/biome check --write ./",
		"security-check": "./src/utils/security-check.sh"
	},
	"keywords": [
		"ai",
		"agents",
		"scrum",
		"development",
		"orchestrator",
		"claude",
		"cursor",
		"gemini"
	],
	"author": "Aizen-Gate Team",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ahmad-ubaidillah/aizen-gate"
	},
	"bugs": {
		"url": "https://github.com/ahmad-ubaidillah/aizen-gate/issues"
	},
	"homepage": "https://github.com/ahmad-ubaidillah/aizen-gate#readme",
	"dependencies": {
		"@inquirer/prompts": "^3.3.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@xenova/transformers": "^2.17.2",
		"better-sqlite3": "^12.6.2",
		"chalk": "^4.1.2",
		"commander": "^11.0.0",
		"dotenv": "^16.3.1",
		"express": "^5.2.1",
		"fs-extra": "^11.1.1",
		"gray-matter": "^4.0.3",
		"js-yaml": "^4.1.0",
		"openmemory-js": "^1.3.3",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"vitest": "^1.1.0"
	}
}
