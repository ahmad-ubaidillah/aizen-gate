{
	"name": "aizen-gate",
	"version": "2.2.4",
	"description": "The Ultimate AI-Orchestration & Specification Shield",
	"main": "dist/index.js",
	"type": "module",
	"bin": {
		"aizen-gate": "./dist/bin/cli.js"
	},
	"files": [
		"dist",
		"bin",
		"src",
		"adapters",
		"agents",
		"commands",
		"completions",
		"dashboard",
		"docs",
		"shared",
		"skill-creator",
		"skills",
		"templates",
		"installer",
		".agent",
		"AIZEN_GATE.md",
		"GEMINI.md",
		"ONBOARDING.md",
		"biome.json",
		"module.yaml",
		"profiles.yaml"
	],
	"scripts": {
		"build": "tsc",
		"postinstall": "node -e \"console.log('\\n✅ Aizen-Gate installed!\\n\\n📖 Quick start: npx aizen-gate help\\n📚 Full guide: See ONBOARDING.md\\n\\n🚀 Ready to use with your IDE!\\n')\"",
		"build:watch": "tsc --watch",
		"clean": "rm -rf dist",
		"test": "vitest",
		"test:run": "vitest run",
		"e2e": "playwright test",
		"az-start": "node ./bin/cli.js start",
		"az-status": "node ./bin/cli.js status",
		"az-tokens": "node ./bin/cli.js tokens",
		"az-kg": "node ./bin/cli.js kg",
		"format": "biome format --write ./",
		"lint": "biome lint --write ./",
		"check": "npx @biomejs/biome check --write ./",
		"typecheck": "tsc --noEmit",
		"security-check": "./src/utils/security-check.sh"
	},
	"keywords": [
		"ai",
		"agents",
		"scrum",
		"development",
		"orchestrator",
		"claude",
		"cursor",
		"gemini"
	],
	"author": "Aizen-Gate Team",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ahmad-ubaidillah/aizen-gate"
	},
	"bugs": {
		"url": "https://github.com/ahmad-ubaidillah/aizen-gate/issues"
	},
	"homepage": "https://github.com/ahmad-ubaidillah/aizen-gate#readme",
	"dependencies": {
		"@clack/prompts": "^1.1.0",
		"@inquirer/prompts": "^8.3.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@xenova/transformers": "^2.17.2",
		"better-sqlite3": "^12.6.2",
		"chalk": "^4.1.2",
		"commander": "^11.0.0",
		"dotenv": "^16.3.1",
		"express": "^5.2.1",
		"fs-extra": "^11.1.1",
		"gray-matter": "^4.0.3",
		"js-yaml": "^4.1.0",
		"node-llama-cpp": "^3.17.1",
		"winston": "^3.11.0",
		"winston-daily-rotate-file": "^4.7.1",
		"ws": "^8.19.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.40.0",
		"@types/express": "^5.0.6",
		"@types/fs-extra": "^11.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.3.5",
		"@types/winston": "^2.4.4",
		"@types/ws": "^8.18.1",
		"@vitest/coverage-v8": "^4.0.18",
		"ts-node": "^10.9.2",
		"typescript": "^5.3.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
